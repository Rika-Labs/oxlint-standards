{
	"extends": ["./anti-slop.json"],
	"plugins": ["typescript", "import", "promise", "unicorn", "oxc", "eslint"],
	"rules": {
		"typescript/consistent-type-imports": "error",
		"typescript/no-misused-promises": "error",
		"typescript/use-unknown-in-catch-callback-variable": "error",
		"typescript/no-unsafe-type-assertion": "error",
		"typescript/no-redundant-type-constituents": "error",
		"typescript/no-deprecated": "error",
		"typescript/ban-ts-comment": [
			"error",
			{
				"ts-ignore": true,
				"ts-nocheck": true,
				"ts-expect-error": { "descriptionFormat": "^: .+" }
			}
		],
		"typescript/restrict-plus-operands": "error",
		"typescript/no-confusing-void-expression": ["error", { "ignoreArrowShorthand": true }],
		"typescript/no-confusing-non-null-assertion": "error",
		"typescript/no-unnecessary-boolean-literal-compare": "error",
		"typescript/no-unnecessary-type-arguments": "error",
		"typescript/no-unnecessary-type-constraint": "error",
		"typescript/prefer-for-of": "error",
		"typescript/prefer-includes": "error",
		"typescript/consistent-type-assertions": ["error", { "assertionStyle": "as" }],
		"typescript/no-empty-object-type": "error",
		"typescript/no-require-imports": "error",
		"typescript/no-namespace": "error",
		"typescript/array-type": ["error", { "default": "generic" }],
		"import/no-reexport": "error",
		"import/no-anonymous-default-export": "error",
		"promise/no-return-wrap": "error",
		"eslint/array-callback-return": "error",
		"eslint/no-useless-return": "error",
		"eslint/no-await-in-loop": "error",
		"eslint/no-param-reassign": "error",
		"eslint/no-empty": "error",
		"eslint/require-yield": "off",
		"eslint/no-console": "error",
		"eslint/no-warning-comments": "error",
		"eslint/no-shadow": ["error", { "hoist": "functions" }],
		"eslint/no-return-assign": "error",
		"eslint/no-loop-func": "error",
		"eslint/no-self-compare": "error",
		"eslint/no-constructor-return": "error",
		"eslint/no-alert": "error",
		"eslint/no-new-func": "error",
		"eslint/curly": ["error", "all"],
		"eslint/no-else-return": "error",
		"eslint/no-implicit-coercion": ["error", { "boolean": true, "number": true, "string": true }],
		"eslint/no-multi-assign": "error",
		"eslint/no-template-curly-in-string": "error",
		"eslint/no-labels": "error",
		"eslint/no-lone-blocks": "error",
		"eslint/prefer-object-has-own": "error",
		"eslint/prefer-object-spread": "error",
		"eslint/prefer-template": "error",
		"eslint/max-params": ["error", 4],
		"eslint/max-depth": ["error", 4],
		"eslint/max-lines-per-function": [
			"error",
			{
				"max": 50,
				"skipBlankLines": true,
				"skipComments": true
			}
		],
		"eslint/complexity": ["error", 10],
		"eslint/no-nested-ternary": "error",
		"eslint/no-debugger": "error",
		"eslint/no-eval": "error",
		"eslint/no-implied-eval": "error",
		"eslint/no-script-url": "error",
		"eslint/prefer-promise-reject-errors": "error",
		"eslint/max-nested-callbacks": ["error", 4],
		"eslint/no-magic-numbers": [
			"error",
			{
				"ignore": [-1, 0, 1, 2]
			}
		],
		"@rikalabs/no-silent-catch-fallback": "error",
		"@rikalabs/no-runtime-compat-fallbacks": "error",
		"@rikalabs/no-catch-return-error-object": "error",
		"@rikalabs/no-unlisted-external-imports": "error",
		"@rikalabs/no-double-type-assertion": "error",
		"@rikalabs/no-ai-debt-comments": "error",
		"@rikalabs/no-json-parse-default-fallback": "error",
		"@rikalabs/no-json-stringify-default-fallback": "error",
		"typescript/no-explicit-any": "error",
		"typescript/no-non-null-assertion": "error",
		"typescript/no-unnecessary-type-assertion": "error",
		"typescript/consistent-type-definitions": ["error", "type"],
		"unicorn/no-static-only-class": "error",
		"unicorn/no-useless-promise-resolve-reject": "error"
	},
	"overrides": [
		{
			"files": [
				"**/*.{test,spec}.{ts,tsx,mts,cts}",
				"**/__tests__/**/*.{ts,tsx,mts,cts}"
			],
			"rules": {
				"eslint/no-magic-numbers": "off",
				"eslint/max-lines-per-function": [
					"error",
					{
						"max": 120,
						"skipBlankLines": true,
						"skipComments": true
					}
				],
				"eslint/complexity": ["error", 20]
			}
		},
		{
			"files": [
				"**/scripts/**/*.{ts,tsx,mts,cts,mjs,cjs}",
				"**/*.config.{ts,mts,cts,js,mjs,cjs}",
				"**/tools/**/*.{ts,tsx,mts,cts}"
			],
			"rules": {
				"eslint/no-console": "off"
			}
		},
		{
			"files": ["**/components/**/*.{tsx,jsx}", "**/app/**/*.{tsx,jsx}"],
			"rules": {
				"eslint/max-lines-per-function": [
					"error",
					{
						"max": 120,
						"skipBlankLines": true,
						"skipComments": true
					}
				],
				"eslint/complexity": ["error", 15]
			}
		}
	]
}
