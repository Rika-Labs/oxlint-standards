{
	"plugins": ["react", "react-perf", "jsx-a11y", "nextjs"],
	"rules": {
		"react/button-has-type": "error",
		"react/exhaustive-deps": "error",
		"react/jsx-filename-extension": "off",
		"react/jsx-key": "error",
		"react/jsx-no-constructed-context-values": "error",
		"react/jsx-no-script-url": "error",
		"react/jsx-no-target-blank": "error",
		"react/no-danger-with-children": "error",
		"react/no-array-index-key": "off",
		"react/void-dom-elements-no-children": "error",
		"react/iframe-missing-sandbox": "error",
		"react/jsx-no-comment-textnodes": "error",
		"react/jsx-no-useless-fragment": "error",
		"react/no-unknown-property": "error",
		"react/no-danger": "error",
		"react/self-closing-comp": "error",
		"react/jsx-pascal-case": "error",
		"react/jsx-boolean-value": "error",
		"react/checked-requires-onchange-or-readonly": "error",
		"react/rules-of-hooks": "error",
		"react/no-unescaped-entities": "error",
		"react/jsx-curly-brace-presence": "error",
		"react/jsx-fragments": "error",
		"react/jsx-props-no-spread-multi": "error",
		"react/no-children-prop": "error",
		"react/forward-ref-uses-ref": "error",
		"react/no-this-in-sfc": "error",
		"react/style-prop-object": "error",
		"react/react-in-jsx-scope": "off",
		"react-perf/jsx-no-jsx-as-prop": "error",
		"react-perf/jsx-no-new-function-as-prop": "error",
		"react-perf/jsx-no-new-object-as-prop": "error",
		"react-perf/jsx-no-new-array-as-prop": "error",
		"jsx-a11y/alt-text": "error",
		"jsx-a11y/anchor-is-valid": "error",
		"jsx-a11y/no-autofocus": "error",
		"jsx-a11y/no-aria-hidden-on-focusable": "error",
		"jsx-a11y/click-events-have-key-events": "error",
		"jsx-a11y/heading-has-content": "error",
		"jsx-a11y/aria-props": "error",
		"jsx-a11y/aria-role": "error",
		"jsx-a11y/no-static-element-interactions": "error",
		"jsx-a11y/no-noninteractive-tabindex": "error",
		"jsx-a11y/iframe-has-title": "error",
		"jsx-a11y/role-has-required-aria-props": "error",
		"jsx-a11y/tabindex-no-positive": "error",
		"jsx-a11y/aria-activedescendant-has-tabindex": "error",
		"jsx-a11y/aria-unsupported-elements": "error",
		"jsx-a11y/autocomplete-valid": "error",
		"jsx-a11y/html-has-lang": "error",
		"jsx-a11y/img-redundant-alt": "error",
		"jsx-a11y/lang": "error",
		"jsx-a11y/media-has-caption": "error",
		"jsx-a11y/no-access-key": "error",
		"jsx-a11y/no-distracting-elements": "error",
		"jsx-a11y/no-redundant-roles": "error",
		"jsx-a11y/prefer-tag-over-role": "error",
		"jsx-a11y/scope": "error",
		"jsx-a11y/anchor-has-content": "error",
		"jsx-a11y/role-supports-aria-props": "error",
		"jsx-a11y/aria-proptypes": "error",
		"jsx-a11y/no-interactive-element-to-noninteractive-role": "error",
		"jsx-a11y/mouse-events-have-key-events": "error",
		"jsx-a11y/label-has-associated-control": "error",
		"nextjs/google-font-display": "error",
		"nextjs/google-font-preconnect": "error",
		"nextjs/inline-script-id": "error",
		"nextjs/no-css-tags": "error",
		"nextjs/no-duplicate-head": "error",
		"nextjs/no-img-element": "error",
		"nextjs/no-async-client-component": "error",
		"nextjs/no-document-import-in-page": "error",
		"nextjs/no-head-import-in-document": "error",
		"nextjs/no-head-element": "error",
		"nextjs/no-html-link-for-pages": "error",
		"nextjs/no-script-component-in-head": "error",
		"nextjs/no-styled-jsx-in-document": "error",
		"nextjs/no-sync-scripts": "error",
		"nextjs/no-title-in-document-head": "error",
		"nextjs/no-unwanted-polyfillio": "error",
		"nextjs/next-script-for-ga": "error",
		"nextjs/no-assign-module-variable": "error",
		"nextjs/no-before-interactive-script-outside-document": "error",
		"nextjs/no-page-custom-font": "error",
		"nextjs/no-typos": "error",
		"@rikalabs/next-no-browser-api-in-server-component": "error",
		"@rikalabs/next-require-server-directive-in-actions": "error",
		"@rikalabs/next-no-use-client-in-root-files": "error",
		"@rikalabs/next-no-pages-router-api-in-app-dir": "error",
		"@rikalabs/react-no-inline-effect-run": "error"
	}
}
